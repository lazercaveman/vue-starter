{
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "singleAttributePerLine": true,
  "printWidth": 100,
  "bracketSameLine": false,
  "arrowParens": "always",
  "insertFinalNewline": true,
  "embeddedLanguageFormatting": "auto",
  "ignorePatterns": [
    "node_modules",
    "coverage",
    "dist",
    ".output",
    ".github",
    ".nuxt",
    ".yarn",
    "**/*.md",
    "**/*.mdx",
  ],
  "sortTailwindcss": {
    "stylesheet": "./src/assets/style/tailwind.css",
  },
}
